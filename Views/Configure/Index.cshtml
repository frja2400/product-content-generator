@model List<ProductContentGenerator.Models.Product>
@{
    ViewData["Title"] = "Configure";
    ViewData["Step"] = "2";

    var brands = Model.Select(p => p.Brand).Where(b => !string.IsNullOrEmpty(b)).Select(b => b!).Distinct().OrderBy(b =>
b).ToList();

    // Hitta den första kategorinivån med variation
    var cat0Values = Model.Select(p => p.Category0).Where(c => !string.IsNullOrEmpty(c)).Select(c =>
c!).Distinct().ToList();
    var cat1Values = Model.Select(p => p.Category1).Where(c => !string.IsNullOrEmpty(c)).Select(c =>
c!).Distinct().ToList();
    var cat2Values = Model.Select(p => p.Category2).Where(c => !string.IsNullOrEmpty(c)).Select(c =>
c!).Distinct().ToList();

    List<string> categories;
    string categoryDataKey;

    if (cat0Values.Count > 1)
    {
        categories = cat0Values.OrderBy(c => c).ToList();
        categoryDataKey = "category0";
    }
    else if (cat1Values.Count > 1)
    {
        categories = cat1Values.OrderBy(c => c).ToList();
        categoryDataKey = "category1";
    }
    else if (cat2Values.Count > 1)
    {
        categories = cat2Values.OrderBy(c => c).ToList();
        categoryDataKey = "category2";
    }
    else
    {
        categories = cat0Values.OrderBy(c => c).ToList();
        categoryDataKey = "category0";
    }

    var fullCount = Model.Count(p => p.DataQuality == ProductContentGenerator.Models.DataQuality.Full);
    var limitedCount = Model.Count(p => p.DataQuality == ProductContentGenerator.Models.DataQuality.Limited);
    var insufficientCount = Model.Count(p => p.DataQuality == ProductContentGenerator.Models.DataQuality.Insufficient);
}

<div class="configure-layout">

    <!-- Vänster panel -->
    <div class="configure-left">
        <div class="configure-header">
            <h2 class="configure-title">Imported products <span class="configure-count">(@Model.Count)</span></h2>
            <div class="quality-summary">
                <span class="quality-badge" onclick="sortByQuality('full')">
                    <span class="quality-dot full"></span> Full (@fullCount)
                </span>
                <span class="quality-badge" onclick="sortByQuality('limited')">
                    <span class="quality-dot limited"></span> Limited (@limitedCount)
                </span>
                <span class="quality-badge" onclick="sortByQuality('insufficient')">
                    <span class="quality-dot insufficient"></span> Insufficient (@insufficientCount)
                </span>
            </div>
        </div>

        <!-- Filter -->
        <div class="filter-section">
            <select id="brandFilter" class="form-select filter-select">
                <option value="">Brand</option>
                @foreach (var brand in brands)
                {
                    <option value="@brand">@brand</option>
                }
            </select>

            <select id="categoryFilter" class="form-select filter-select" data-category-key="@categoryDataKey">
                <option value="">Category</option>
                @foreach (var category in categories)
                {
                    <option value="@category">@category</option>
                }
            </select>

            <div id="activeTags" class="active-tags"></div>

            <p class="selected-count"><span id="selectedCount">@Model.Count</span> of @Model.Count products selected</p>
        </div>

        <!-- Produktlista -->
        <div class="product-list" id="productList">
            @foreach (var product in Model)
            {
                <div class="product-item" data-variant-id="@product.VariantId" data-brand="@product.Brand"
                     data-category0="@product.Category0" data-category1="@product.Category1"
                     data-category2="@product.Category2" data-quality="@product.DataQuality">
                    <input type="checkbox" class="product-checkbox" checked />
                    <div class="product-info" onclick="loadDetail('@product.VariantId', this.closest('.product-item'))">
                        <span class="product-name">@product.DisplayName</span>
                        <span class="product-variant">@product.VariantId</span>
                    </div>
                    <span class="quality-dot @product.DataQuality.ToString().ToLower()"></span>
                </div>
            }
        </div>
    </div>

    <!-- Mitten panel -->
    <div class="configure-middle" id="detailPanel">
        <p class="detail-placeholder">Select a product to view details</p>
    </div>

    <!-- Höger panel -->
    <div class="configure-right">
        <form method="post" action="/Configure/RunSample" id="sampleForm">
            <div id="selectedProductInputs"></div>
            <p class="prompt-label">AI Instructions</p>
            <textarea class="prompt-textarea" name="prompt">@ViewBag.Prompt</textarea>
            <p class="prompt-hint">Adjust prompt if needed</p>
        </form>
        <div class="configure-right-actions">
            <div class="prompt-actions">
                <input type="number" class="sample-input" id="sampleCount" name="sampleCount"
                       value="@ViewBag.SampleCount" min="3" max="10" form="sampleForm" />
                <button type="submit" class="btn-sample" id="sampleBtn" form="sampleForm">Run sample</button>
            </div>
            <button class="btn-cancel cancel-import-btn">Cancel import</button>
        </div>
    </div>