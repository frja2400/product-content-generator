@model List<ProductContentGenerator.Models.Product>

@{
    ViewData["Title"] = "Review";
    ViewData["Step"] = "3";

    var generatedProducts = Model.Where(p => p.GeneratedDescription != null).ToList();
    var insufficientCount = Model.Count(p => p.DataQuality != ProductContentGenerator.Models.DataQuality.Insufficient);
}

<div class="review-layout">

    <!-- Vänster panel – produktkort -->
    <div class="review-left">
        @foreach (var product in generatedProducts)
        {
            var hasNoDescriptions = string.IsNullOrWhiteSpace(product.LongDescription) &&
                                    string.IsNullOrWhiteSpace(product.ShortDescription) &&
                                    string.IsNullOrWhiteSpace(product.ContentDescription) &&
                                    string.IsNullOrWhiteSpace(product.UsageDescription) &&
                                    string.IsNullOrWhiteSpace(product.FeatureBullets) &&
                                    string.IsNullOrWhiteSpace(product.AffectingSubstances);

            var isLimited = product.DataQuality == ProductContentGenerator.Models.DataQuality.Limited;

            <div class="product-card" data-variant-id="@product.VariantId">
                <div class="product-card-header">
                    <div class="product-card-title">
                        <h3 class="card-name">@product.DisplayName</h3>
                        <span class="card-variant">@product.VariantId</span>
                    </div>
                    <span class="quality-dot @product.DataQuality.ToString().ToLower()"></span>
                </div>

                <div class="card-generated">
                    <h4 class="card-section-label">Generated description</h4>
                    <div class="card-text">@Html.Raw((product.GeneratedDescription ?? "").Replace("\n", "<br>"))</div>
                </div>

                @if (product.GenerationFailed)
                {
                    <p class="card-error">Generation failed – showing original text.</p>
                    <button class="btn-retry" data-variant-id="@product.VariantId">Try again</button>
                }

                @if (isLimited)
                {
                    <p class="card-warning">Generated from limited data – review carefully.</p>
                }

                <details class="card-original">
                    <summary>Original data</summary>
                    <div class="card-original-content">
                        @if (!string.IsNullOrWhiteSpace(product.LongDescription))
                        {
                            <div class="original-field">
                                <label>Description</label>
                                <p>@product.LongDescription</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(product.ShortDescription))
                        {
                            <div class="original-field">
                                <label>Short description</label>
                                <p>@product.ShortDescription</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(product.ContentDescription))
                        {
                            <div class="original-field">
                                <label>Content</label>
                                <p>@product.ContentDescription</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(product.UsageDescription))
                        {
                            <div class="original-field">
                                <label>Usage</label>
                                <p>@product.UsageDescription</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(product.FeatureBullets))
                        {
                            <div class="original-field">
                                <label>Feature bullets</label>
                                <p>@product.FeatureBullets</p>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(product.AffectingSubstances))
                        {
                            <div class="original-field">
                                <label>Affecting substances</label>
                                <p>@product.AffectingSubstances</p>
                            </div>
                        }
                        @if (hasNoDescriptions)
                        {
                            <p class="card-no-data">No original description available.</p>
                        }
                    </div>
                </details>
            </div>
        }
    </div>

    <!-- Höger panel – prompt och åtgärder -->
    <div class="review-right">
        <form method="post" action="/Configure/RunSample" id="rerunForm">
            <p class="prompt-label">AI Instructions</p>
            <textarea class="prompt-textarea" name="prompt">@ViewBag.Prompt</textarea>
            <p class="prompt-hint">Adjust prompt if needed</p>
        </form>

        <div class="review-actions">
            <div class="prompt-actions">
                <input type="number" class="sample-input" id="sampleCountRerun" value="@ViewBag.SampleCount" min="3"
                       max="10" />
                <span class="sample-label">sample products</span>
            </div>
            <button class="btn-sample" id="rerunSampleBtn">Run sample again</button>
            <form method="post" action="/Configure/RunAll" id="runAllForm">
                <input type="hidden" name="prompt" id="runAllPrompt" />
                <button type="submit" class="btn-run-all" id="runAllBtn"
                        onclick="document.getElementById('runAllPrompt').value = document.querySelector('.prompt-textarea').value">
                    Run all products (@ViewBag.EligibleCount)
                </button>
            </form>
            <div class="review-secondary-actions">
                <a href="/Configure" class="btn-text-link">Back to configure</a>
                <button class="btn-cancel btn-cancel-inline cancel-import-btn">Cancel import</button>
            </div>
        </div>
    </div>

</div>