@{
    ViewData["Title"] = "Upload";
    ViewData["Step"] = "1";
}

<div class="upload-container">
    <h1 class="upload-title">Product Content Generation</h1>

    @if (TempData["Error"] != null)
    {
        <p class="upload-error">@TempData["Error"]</p>
    }

    <form method="post" action="/Upload/Upload" enctype="multipart/form-data" id="uploadForm">
        <div class="drop-zone" id="dropZone">
            <input type="file" name="file" id="fileInput" accept=".xlsx,.xml" hidden />
            <div class="drop-zone-content">
                <i class="bi bi-cloud-arrow-up drop-zone-icon"></i>
                <p class="drop-zone-text">Drag and drop XML / XLSX</p>
                <p class="drop-zone-filename" id="fileName"></p>
                <button type="button" class="btn-upload" id="uploadBtn">Upload file</button>
            </div>
        </div>
    </form>
</div>